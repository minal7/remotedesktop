# RemoteDesktop Host Configuration
# Copy this file to .env and fill in your CloudKit API Token

# Required: The CloudKit API Web Token for your developer container
REMOTE_DESKTOP_CLOUDKIT_API_TOKEN="your-cloudkit-api-token-here"

# Optional: CloudKit Environment (development or production). Defaults to development.
REMOTE_DESKTOP_CLOUDKIT_ENV="development"

# Optional: CloudKit Container ID. Defaults to iCloud.com.threadmark.remotedesktop.
# REMOTE_DESKTOP_CLOUDKIT_CONTAINER="iCloud.com.threadmark.remotedesktop"

# Optional: Local binding address for Apple ID redirect callback
# REMOTE_DESKTOP_AUTH_CALLBACK_BIND="127.0.0.1:48172"

# Optional: Callback path configured on the API Token
# REMOTE_DESKTOP_AUTH_CALLBACK_PATH="/icloud-auth-callback"

# Optional: How often to poll CloudKit for updates (in seconds)
# REMOTE_DESKTOP_POLL_SECONDS=2
